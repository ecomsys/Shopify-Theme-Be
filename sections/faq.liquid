<!-- sections/custom-faq.liquid -->

{%- style -%}
  /* Убираем стандартный треугольник браузера */
  summary::-webkit-details-marker { display: none; }
  summary { list-style: none; }

  /* МАГИЯ ПЕРЕКЛЮЧЕНИЯ + и - */
  /* Когда details открыт, скрываем плюс и показываем минус */
  details[open] summary .faq-icon-plus { opacity: 0; }
  details[open] summary .faq-icon-minus { opacity: 1; }
{%- endstyle -%}

<!-- Слегка серый фон, чтобы белые карточки выделялись -->
<section class="tw:bg-seriy tw:text-grayscale-950 tw:px-[1.6rem]">
  <div class="tw:max-w-[112rem] tw:mx-auto tw:py-[6rem]">
    
    <!-- Заголовок секции -->
    {%- if section.settings.heading != blank -%}
      <div class="tw:text-center tw:mb-12">
        <h2 class="tw:text-[4rem] tw:font-medium tw:tracking-[-0.04em] tw:leading-[1.2]">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <!-- Контейнер для карточек -->
    <div class="tw:flex tw:flex-col tw:gap-6">
      {%- for block in section.blocks -%}
        
        <!-- КАРТОЧКА -->
        <details class="tw:group tw:bg-white tw:rounded-xl tw:border tw:border-gray-200 tw:shadow-sm tw:overflow-hidden" {{ block.shopify_attributes }}>
          
          <!-- Заголовок вопроса -->
          <summary class="tw:flex tw:justify-between tw:items-center tw:p-[2rem] tw:cursor-pointer tw:hover:bg-gray-50 tw:transition-colors">
            
            <span class="tw:text-[2rem] tw:font-medium tw:pr-8 tw:leading-[1.4] tw:tracking-[-0.04em]">
              {{ block.settings.question }}
            </span>

            <!-- Контейнер для иконок -->
            <span class="tw:relative tw:w-[2.8rem] tw:h-[2.8rem] tw:flex-shrink-0 tw:flex tw:items-center tw:justify-center">
              
              <!-- Иконка ПЛЮС -->
              <!-- Убрали tw:group-open, добавили класс faq-icon-plus -->
              <svg class="faq-icon-plus tw:absolute tw:w-full tw:h-full tw:text-golden tw:transition-opacity tw:duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6"></path>
              </svg>

              <!-- Иконка МИНУС -->
              <!-- Убрали tw:group-open, добавили класс faq-icon-minus -->
              <svg class="faq-icon-minus tw:absolute tw:w-full tw:h-full tw:text-golden tw:opacity-0 tw:transition-opacity tw:duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 12H6"></path>
              </svg>

            </span>
          </summary>

          <!-- Текст ответа -->
          <div class="tw:px-[2rem] tw:pb-[2rem] tw:text-[1.6rem] tw:text-[#8b867a] tw:leading-[1.5] tw:tracking-[-0.04em]">
            {{ block.settings.answer }}
          </div>

        </details>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "BERGNZ FAQ",
  "tag": "section",
  "class": "section-faq",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Frequently Asked Questions",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "default": "What is your return policy?",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "default": "<p>We accept returns within 30 days of purchase. Items must be in their original condition.</p>",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BERGNZ FAQ",
      "blocks": [
        {
          "type": "question"
        },
        {
          "type": "question"
        },
        {
          "type": "question"
        }
      ]
    }
  ]
}
{% endschema %}