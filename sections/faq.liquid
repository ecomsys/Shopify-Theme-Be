<!-- sections/custom-faq.liquid -->

{%- style -%}
  /* Убираем стандартный треугольник браузера */
  summary::-webkit-details-marker {
    display: none;
  }
  summary {
    list-style: none;
  }

  /* МАГИЯ ПЕРЕКЛЮЧЕНИЯ + и - */
  /* Когда details открыт, скрываем плюс и показываем минус */
  details[open] summary .faq-icon-plus {
    opacity: 0;
  }
  details[open] summary .faq-icon-minus {
    opacity: 1;
  }
{%- endstyle -%}

<!-- Слегка серый фон, чтобы белые карточки выделялись -->
<section class="tw:bg-seriy tw:text-grayscale-950 tw:px-[1.6rem]">
  <div class="tw:max-w-[112rem] tw:mx-auto tw:py-[6rem]">
    <!-- Заголовок секции -->
    {%- if section.settings.heading != blank -%}
      <div class="tw:flex tw:flex-col tw:items-center tw:gap-[1rem] tw:mb-[3rem]">

        <div class="tw:text-center">
          <h2 class="tw:text-[4rem] tw:font-medium tw:tracking-[-0.04em] tw:leading-[1.2]">
            {{ section.settings.heading }}
          </h2>
        </div>

        <!-- БЛОК С ОТЗЫВАМИ -->
        {%- if section.settings.rating_score != blank and section.settings.review_count != blank -%}
          <div class="tw:mx-auto tw:inline-flex tw:items-center tw:justify-center tw:gap-2 tw:py-[0.8rem] tw:px-[2rem] tw:bg-[#e5dccb] tw:rounded-full">
            <!-- Текст со статистикой -->
            <span class="tw:pt-1 tw:text-[1.4rem] tw:leading-[1.43] tw:tracking-[-0.04em] tw:text-center">
              Rated {{ section.settings.rating_score }}/5 based on {{ section.settings.review_count }} reviews
            </span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Контейнер для карточек -->
    <div class="tw:flex tw:flex-col tw:gap-6">
      {%- for block in section.blocks -%}
        <!-- КАРТОЧКА -->
        <details
          class="faq-animate tw:group tw:bg-white tw:rounded-xl tw:border tw:border-gray-200 tw:shadow-sm tw:overflow-hidden"
          {{ block.shopify_attributes }}
        >
          <!-- Заголовок вопроса -->
          <summary class="tw:flex tw:justify-between tw:items-start tw:p-[2rem] tw:cursor-pointer tw:transition-colors">
            <span class="tw:text-[2rem] tw:font-medium tw:pr-8 tw:leading-[1.4] tw:tracking-[-0.04em]">
              {{ block.settings.question }}
            </span>

            <!-- Контейнер для иконок -->
            <span class="tw:relative tw:w-[2.8rem] tw:h-[2.8rem] tw:flex-shrink-0 tw:flex tw:items-center tw:justify-center">
              <!-- Иконка ПЛЮС -->
              <!-- Убрали tw:group-open, добавили класс faq-icon-plus -->
              <svg
                class="faq-icon-plus tw:absolute tw:w-full tw:h-full tw:text-golden tw:transition-opacity tw:duration-300"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6"></path>
              </svg>

              <!-- Иконка МИНУС -->
              <!-- Убрали tw:group-open, добавили класс faq-icon-minus -->
              <svg
                class="faq-icon-minus tw:absolute tw:w-full tw:h-full tw:text-golden tw:opacity-0 tw:transition-opacity tw:duration-300"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 12H6"></path>
              </svg>
            </span>
          </summary>

          <!-- Текст ответа -->
          <div class="faq-content tw:px-[2rem] tw:pb-[2rem] tw:text-[1.6rem] tw:text-[#8b867a] tw:leading-[1.5] tw:tracking-[-0.04em]">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  // Анимация аккордеона для <details>
  document.querySelectorAll('details.faq-animate').forEach((el) => {
    const summary = el.querySelector('summary');
    const content = el.querySelector('.faq-content');

    // Перехватываем клик
    summary.addEventListener('click', (e) => {
      e.preventDefault(); // Останавливаем мгновенное открытие браузера

      // Если анимация уже запущена, ничего не делаем
      if (el.animating) return;

      if (el.open) {
        // ЗАКРЫТИЕ
        shrink();
      } else {
        // ОТКРЫТИЕ
        open();
      }
    });

    function shrink() {
      el.animating = true;
      const startHeight = el.offsetHeight + 'px';
      const endHeight = summary.offsetHeight + 'px';
      
      // На время анимации скрываем выпадающий текст за границами
      el.style.overflow = 'hidden';

      const animation = el.animate([
        { height: startHeight },
        { height: endHeight }
      ], {
        duration: 300,
        easing: 'ease-out'
      });

      animation.onfinish = () => {
        el.open = false; // Браузер закрывает details
        el.style.overflow = '';
        el.animating = false;
      };
      animation.oncancel = () => {
        el.style.overflow = '';
        el.animating = false;
      };
    }

    function open() {
      el.animating = true;
      el.style.height = el.offsetHeight + 'px';
      el.open = true; // Браузер открывает details (нужно, чтобы посчитать высоту контента)
      
      const startHeight = el.offsetHeight + 'px';
      const endHeight = summary.offsetHeight + content.offsetHeight + 'px';
      
      el.style.overflow = 'hidden';

      const animation = el.animate([
        { height: startHeight },
        { height: endHeight }
      ], {
        duration: 300,
        easing: 'ease-out'
      });

      animation.onfinish = () => {
        el.style.overflow = '';
        el.style.height = '';
        el.animating = false;
      };
      animation.oncancel = () => {
        el.style.overflow = '';
        el.style.height = '';
        el.animating = false;
      };
    }
  });
</script>

{% schema %}
{
  "name": "BERGNZ FAQ",
  "tag": "section",
  "class": "section-faq",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Frequently Asked Questions",
      "label": "Heading"
    },
    {
      "type": "header",
      "content": "Reviews Statistics"
    },
    {
      "type": "text",
      "id": "rating_score",
      "default": "4.8",
      "label": "Average rating score (e.g., 4.8)"
    },
    {
      "type": "text",
      "id": "review_count",
      "default": "2,847",
      "label": "Total number of reviews (e.g., 2,847)"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "default": "What is your return policy?",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "default": "<p>We accept returns within 30 days of purchase. Items must be in their original condition.</p>",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BERGNZ FAQ",
      "blocks": [
        {
          "type": "question"
        },
        {
          "type": "question"
        },
        {
          "type": "question"
        }
      ]
    }
  ]
}
{% endschema %}
