<!-- sections/custom-newsletter-banner.liquid -->

<section class="tw:relative tw:w-full tw:min-h-[57.2rem] tw:lg:h-[57.2rem] tw:flex tw:items-center tw:overflow-hidden">
  <!-- Фоновое изображение -->
  {%- if section.settings.bg_image != blank -%}
    {%- assign img_width = 1920 -%}
    {%- assign img_height = img_width | divided_by: section.settings.bg_image.aspect_ratio -%}
    <img
      src="{{ section.settings.bg_image | image_url: width: 1920 }}"
      alt=""
      width="{{ img_width }}"
      height="{{ img_height }}"
      class="tw:absolute tw:inset-0 tw:w-full tw:h-full tw:object-cover tw:z-0"
      loading="lazy"
    >
  {%- else -%}
    <div class="tw:absolute tw:inset-0 tw:bg-gray-900 tw:z-0"></div>
  {%- endif -%}

  <!-- Затемнение фона (чтобы текст читался) -->
  <div class="tw:absolute tw:inset-0 tw:bg-black/50 tw:z-[1]"></div>

  <!-- Контент -->
  <div class="tw:relative tw:z-10 tw:w-full tw:max-w-[112rem] tw:mx-auto tw:px-[1.6rem] tw:py-[4rem] tw:lg:py-0 tw:flex tw:flex-col tw:lg:flex-row tw:items-center tw:justify-between tw:gap-[4rem]">
    <!-- ЛЕВАЯ ЧАСТЬ: Текст -->
    <div class="tw:text-white tw:text-center tw:lg:text-left">
      <h2 class="tw:text-[6rem] tw:font-bold tw:leading-[1.1] tw:tracking-[-0.04em]">
        {{ section.settings.heading_line_1 -}}
        <br>
        {{ section.settings.heading_line_2 }}
      </h2>
    </div>

    <!-- ПРАВАЯ ЧАСТЬ: Карточка с формой -->
    <div class="tw:bg-white tw:rounded-2xl tw:p-[3rem] tw:w-full tw:max-w-[48rem] tw:flex tw:flex-col tw:min-h-[42rem]">
      <!-- Ряд 1: Аватар + Имя/Должность -->
      <div class="tw:flex tw:items-center tw:gap-[2rem] tw:mb-[2rem]">
        <div class="tw:w-[10rem] tw:h-[10rem] tw:flex-shrink-0 tw:rounded-lg tw:overflow-hidden tw:bg-gray-200">
            
          {%- if section.settings.avatar != blank -%}
            {%- assign avatar_width = 200 -%}
            {%- assign avatar_height = avatar_width | divided_by: section.settings.avatar.aspect_ratio -%}
            <img
              src="{{ section.settings.avatar | image_url: width: 200 }}"
              alt="Doctor"
              width="{{ avatar_width }}"
              height="{{ avatar_height }}"
              class="tw:w-full tw:h-full tw:object-cover"
            >
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'tw:w-full tw:h-full' }}
          {%- endif -%}
        </div>
        <div>
          <p class="tw:text-[1.8rem] tw:font-bold tw:tracking-[-0.04em] tw-text-grayscale-950">
            {{ section.settings.doctor_name }}
          </p>
          <p class="tw:text-[1.4rem] tw:text-[#8b867a] tw:tracking-[-0.04em]">{{ section.settings.doctor_role }}</p>
        </div>
      </div>

      <!-- Ряд 2: Серый текст -->
      <div class="tw:text-[1.6rem] tw:text-[#8b867a] tw:leading-[1.5] tw:tracking-[-0.04em] tw:flex-1 tw:mb-[2rem]">
        {{ section.settings.text }}
      </div>

      <!-- Ряд 3: Форма (Прижата к низу) -->
      <div class="tw:mt-auto">
        {%- form 'customer', id: 'BannerNewsletter', class: 'newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">

          <!-- Инпут с Label -->
          <div class="tw:mb-[1.5rem]">
            <label
              for="BannerEmail-{{ section.id }}"
              class="tw:block tw:text-[1.2rem] tw:text-[#8b867a] tw:mb-2 tw:tracking-[-0.04em]"
            >
              Email address
            </label>
            <input
              id="BannerEmail-{{ section.id }}"
              type="email"
              name="contact[email]"
              class="tw:w-full tw:border tw:border-gray-300 tw:rounded-md tw:px-4 tw:py-3 tw:text-[1.4rem] tw:placeholder-gray-400 tw:focus:outline-none tw:focus:ring-2 tw:focus:ring-black"
              placeholder="your@email.com"
              required
            >
          </div>

          <!-- Чекбокс -->
          <label class="tw:flex tw:items-start tw:gap-3 tw:cursor-pointer tw:mb-[1.5rem]">
            <input
              type="checkbox"
              class="tw:mt-1 tw:w-[1.6rem] tw:h-[1.6rem] tw:rounded tw:border-gray-300 tw:text-black tw:focus:ring-black"
              required
            >
            <span class="tw:text-[1.2rem] tw:text-[#8b867a]"
              >By clicking "Subscribe", I agree to the
              <a
                href="{% if section.settings.privacy_link != blank %}{{ section.settings.privacy_link }}{% else %}#{% endif %}"
                class="tw:underline tw:hover:text-black"
                >privacy policy</a
              >.</span
            >
          </label>

          <!-- Кнопка -->
          <button
            type="submit"
            class="tw:w-full tw:bg-black tw:text-white tw:py-4 tw:rounded-md tw:text-[1.4rem] tw:font-medium tw:hover:bg-gray-800 tw:transition-colors tw:duration-300"
          >
            Subscribe
          </button>

          {%- if form.posted_successfully? -%}
            <h3
              class="tw:text-green-600 tw:text-[1.4rem] tw:font-medium tw:mt-4 tw:text-center"
              tabindex="-1"
              autofocus
            >
              Thank you for subscribing!
            </h3>
          {%- endif -%}

          {%- if form.errors -%}
            <small class="tw:text-red-500 tw:text-[1.2rem] tw:mt-2 tw:block" id="BannerNewsletter-error">
              {{ form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email }}
            </small>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "WEBLEGKO NEWSLETTER",
  "tag": "section",
  "class": "section-newsletter-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "default": "Stay",
      "label": "Heading Line 1"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "default": "Updated",
      "label": "Heading Line 2"
    },
    {
      "type": "header",
      "content": "Doctor Card"
    },
    {
      "type": "image_picker",
      "id": "avatar",
      "label": "Doctor Avatar (100x100px)"
    },
    {
      "type": "text",
      "id": "doctor_name",
      "default": "Dr. Eric Berg",
      "label": "Doctor Name"
    },
    {
      "type": "text",
      "id": "doctor_role",
      "default": "Health Specialist",
      "label": "Doctor Role / Title"
    },
    {
      "type": "textarea",
      "id": "text",
      "default": "Get the latest health tips, exclusive offers, and expert advice delivered straight to your inbox. Join our community today and take the first step towards a healthier you.",
      "label": "Description Text"
    },
    {
      "type": "url",
      "id": "privacy_link",
      "label": "Privacy Policy Link"
    }
  ],
  "presets": [
    {
      "name": "WEBLEGKO NEWSLETTER"
    }
  ]
}
{% endschema %}
