<!-- sections/home-slider.liquid -->
<section class="tw:relative tw:max-w-[144rem] tw:mx-auto tw:w-full tw:h-[20rem] tw:md:h-[26rem] tw:bg-gray-100 tw:overflow-hidden">
  
  <!-- Главный контейнер Swiper -->
  <div class="swiper myProductSwiper tw:w-full tw:h-full">
    <div class="swiper-wrapper">
      
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          
          <!-- ОДИН СЛАЙД -->
          <div class="swiper-slide tw:relative tw:h-full" {{ block.shopify_attributes }}>
            
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="tw:block tw:w-full tw:h-full tw:group">
            {% endif %}

              <!-- Картинка -->
              {% if block.settings.image != blank %}
                {{ 
                  block.settings.image 
                  | image_url: width: 1200 
                  | image_tag: 
                      class: 'tw:w-full tw:h-full tw:object-cover tw:transition-transform tw:duration-500 tw:group-hover:scale-105',
                      loading: 'lazy',
                      widths: '600, 900, 1200',
                      alt: 'Промо слайд'
                }}
              {% else %}
                {{ 'lifestyle-2' | placeholder_svg_tag: 'tw:w-full tw:h-full tw:object-cover tw:opacity-50' }}
              {% endif %}

            {% if block.settings.link != blank %}
              </a>
            {% endif %}

          </div>
        {% endfor %}
      {% else %}
        <div class="swiper-slide tw:flex tw:items-center tw:justify-center tw:bg-gray-200 tw:text-gray-500 tw:font-inter">
          Добавьте слайды в настройках секции
        </div>
      {% endif %}

    </div>
    
    <!-- СТРЕЛКА ВЛЕВО (Chevron Left) -->
    <button class="home-button-prev tw:absolute tw:left-2 tw:top-1/2 tw:-translate-y-1/2 tw:z-10 tw:w-[4.5rem] tw:h-[4.5rem] tw:flex tw:items-center tw:justify-center tw:text-white tw:hover:bg-black/10 tw:rounded-full tw:transition-all" aria-label="Предыдущий слайд">
      <svg class="tw:w-[3.2rem] tw:h-[3.2rem]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path>
      </svg>
    </button>

    <!-- СТРЕЛКА ВПРАВО (Chevron Right) -->
    <button class="home-button-next tw:absolute tw:right-2 tw:top-1/2 tw:-translate-y-1/2 tw:z-10 tw:w-[4.5rem] tw:h-[4.5rem] tw:flex tw:items-center tw:justify-center tw:text-white tw:hover:bg-black/10 tw:rounded-full tw:transition-all" aria-label="Следующий слайд">
      <svg class="tw:w-[3.2rem] tw:h-[3.2rem]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
      </svg>
    </button>

  </div>

  <!-- Инициализация Swiper (БЕЗ пагинации) -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof Swiper !== 'undefined') {
        new Swiper('.myProductSwiper', {
          loop: true, // Бесконечная прокрутка
          speed: 600, // Плавность анимации
          autoplay: {
            delay: 4000, // Автопереключение каждые 4 сек
            disableOnInteraction: false,
          },
          navigation: {
            nextEl: '.home-button-next',
            prevEl: '.home-button-prev',
          },
          // Пагинация полностью удалена отсюда
          breakpoints: {
            320: {
              slidesPerView: 1,
              spaceBetween: 0,
            }
          }
        });
      }
    });
  </script>
</section>

{% schema %}
{
  "name": "WEBLEGKO TOP SLIDER",
  "class": "section-home-slider",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Слайд",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Изображение"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Ссылка (на товар или коллекцию)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WEBLEGKO TOP SLIDER",
      "blocks": [
        { "type": "slide" }        
      ]
    }
  ]
}
{% endschema %}