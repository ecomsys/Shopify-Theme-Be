<!-- sections/home-slider.liquid -->
<section class="relative w-full h-50 md:h-165  bg-gray-100 overflow-hidden">
  
  <!-- Главный контейнер Swiper -->
  <div class="swiper myProductSwiper w-full h-full">
    <div class="swiper-wrapper">
      
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          
          <!-- ОДИН СЛАЙД -->
          <div class="swiper-slide relative h-full" {{ block.shopify_attributes }}>
            
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="block w-full h-full group">
            {% endif %}

              <!-- Картинка -->
              {% if block.settings.image != blank %}
                {{ 
                  block.settings.image 
                  | image_url: width: 1200 
                  | image_tag: 
                      class: 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105',
                      loading: 'lazy',
                      widths: '600, 900, 1200',
                      alt: 'Промо слайд'
                }}
              {% else %}
                {{ 'lifestyle-2' | placeholder_svg_tag: 'w-full h-full object-cover opacity-50' }}
              {% endif %}

            {% if block.settings.link != blank %}
              </a>
            {% endif %}

          </div>
        {% endfor %}
      {% else %}
        <div class="swiper-slide flex items-center justify-center bg-gray-200 text-gray-500 font-inter">
          Добавьте слайды в настройках секции
        </div>
      {% endif %}

    </div>
    
    <!-- СТРЕЛКА ВЛЕВО (Chevron Left) -->
    <!-- top-1/2 -translate-y-1/2 = строго по центру высоты -->
    <!-- left-8 = ровно 2rem (3.2rem) от левого края -->
    <button class="home-button-prev absolute left-8 top-1/2 -translate-y-1/2 z-10 w-16 h-16 flex items-center justify-center text-white hover:bg-black/10 rounded-full transition-all" aria-label="Предыдущий слайд">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path>
      </svg>
    </button>

    <!-- СТРЕЛКА ВПРАВО (Chevron Right) -->
    <!-- right-8 = ровно 2rem (3.2rem) от правого края -->
    <button class="home-button-next absolute right-8 top-1/2 -translate-y-1/2 z-10 w-16 h-16 flex items-center justify-center text-white hover:bg-black/10 rounded-full transition-all" aria-label="Следующий слайд">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
      </svg>
    </button>

  </div>

  <!-- Инициализация Swiper (БЕЗ пагинации) -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      if (typeof Swiper !== 'undefined') {
        new Swiper('.myProductSwiper', {
          loop: true, // Бесконечная прокрутка
          speed: 600, // Плавность анимации
          autoplay: {
            delay: 4000, // Автопереключение каждые 4 сек
            disableOnInteraction: false,
          },
          navigation: {
            nextEl: '.home-button-next',
            prevEl: '.home-button-prev',
          },
          // Пагинация полностью удалена отсюда
          breakpoints: {
            320: {
              slidesPerView: 1,
              spaceBetween: 0,
            }
          }
        });
      }
    });
  </script>
</section>

{% schema %}
{
  "name": "WEBLEGKO Home cлайдер",
  "class": "section-home-slider",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Слайд",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Изображение"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Ссылка (на товар или коллекцию)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "WEBLEGKO Home cлайдер",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}